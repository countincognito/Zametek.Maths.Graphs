# Generic hygiene for every file in the repository. Language-specific rules
# live in dotnet/.editorconfig (self-contained: it declares root = true) and,
# for the Rust sources, are enforced by rustfmt.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Trailing double-spaces are meaningful hard breaks in Markdown.
trim_trailing_whitespace = false
